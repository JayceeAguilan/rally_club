rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin(uid) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(uid))
        && get(/databases/$(database)/documents/users/$(uid)).data.role == 'admin';
    }

    function isAdminForClub(clubId) {
      return isAdmin(request.auth.uid)
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clubId == clubId;
    }

    function isMemberOfClub(clubId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.clubId == clubId;
    }

    function initialOwnPlayerCreateAllowed() {
      return isSignedIn()
        && request.resource.data.clubId is string
        && request.resource.data.ownerUid == request.auth.uid
        && !exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function currentUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isLinkedOwnPlayer(playerId, clubId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && currentUserData().playerId == playerId
        && currentUserData().clubId == clubId;
    }

    function ownProfileUpdateAllowed(playerId) {
      return isSignedIn()
        && (
          resource.data.ownerUid == request.auth.uid
          || isLinkedOwnPlayer(playerId, resource.data.clubId)
        )
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'name',
          'gender',
          'skillLevel',
          'isAvailable',
          'notes',
          'profileImageBase64',
          'updatedAt',
        ]);
    }

    function ownParticipationSyncAllowed(playerId) {
      return isSignedIn()
        && (
          resource.data.ownerUid == request.auth.uid
          || isLinkedOwnPlayer(playerId, resource.data.clubId)
        )
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && currentUserData().playerId == playerId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'countsAsPlayer',
          'isAvailable',
          'updatedAt',
        ])
        && request.resource.data.countsAsPlayer ==
          (currentUserData().role == 'admin' ? 0 : 1)
        && (
          currentUserData().role == 'admin'
            ? request.resource.data.isAvailable == 0
            : request.resource.data.isAvailable == resource.data.isAvailable
        );
    }

    function adminOnlyPlayerResultUpdate() {
      return isAdminForClub(resource.data.clubId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastResult']);
    }

    // Deny all by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Users: only the owner can read/write their own user doc
    match /users/{uid} {
      allow read: if isSignedIn() && request.auth.uid == uid;

      allow create: if isSignedIn()
        && request.auth.uid == uid
        && request.resource.data.uid == uid
        && request.resource.data.email is string
        && request.resource.data.playerId is string
        && request.resource.data.clubId is string
        && request.resource.data.role == 'member'
        && request.resource.data.joinedAt is string;

      allow update: if isSignedIn()
        && request.auth.uid == uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'announcementLastSeenAt',
        ]);

      allow delete: if false;
    }

    // Clubs: any authenticated user can read; no client writes
    match /clubs/{clubId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // Players: authenticated club members can read; only owner can update their own player
    match /players/{playerId} {
      allow read: if isSignedIn();

      allow create: if initialOwnPlayerCreateAllowed()
        || isAdminForClub(request.resource.data.clubId);

      allow update: if ownProfileUpdateAllowed(playerId)
        || ownParticipationSyncAllowed(playerId)
        || isAdminForClub(resource.data.clubId)
        || adminOnlyPlayerResultUpdate();

      allow delete: if false;
    }

    // Matches: authenticated club members can read and create; no client updates/deletes
    match /matches/{matchId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && request.resource.data.clubId is string
        && request.resource.data.createdByUid == request.auth.uid
        && isAdmin(request.auth.uid);

      allow update, delete: if false;
    }

    // Announcements: admins can create scheduled play announcements; club members can read.
    match /announcements/{announcementId} {
      allow read: if isMemberOfClub(resource.data.clubId);

      allow create: if isAdminForClub(request.resource.data.clubId)
        && request.resource.data.createdByUid == request.auth.uid
        && request.resource.data.title is string
        && request.resource.data.location is string
        && request.resource.data.scheduledAt is string
        && request.resource.data.createdByName is string;

      allow update, delete: if false;
    }

    // Announcement comments: club members can comment, authors can edit/delete their own,
    // and admins can delete any comment in their club.
    match /announcement_comments/{commentId} {
      allow read: if isMemberOfClub(resource.data.clubId);

      allow create: if isMemberOfClub(request.resource.data.clubId)
        && request.resource.data.authorUid == request.auth.uid
        && request.resource.data.announcementId is string
        && request.resource.data.authorName is string
        && request.resource.data.text is string
        && exists(/databases/$(database)/documents/announcements/$(request.resource.data.announcementId))
        && get(/databases/$(database)/documents/announcements/$(request.resource.data.announcementId)).data.clubId == request.resource.data.clubId;

      allow update: if isMemberOfClub(resource.data.clubId)
        && resource.data.authorUid == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'text',
          'updatedAt',
        ]);

      allow delete: if isMemberOfClub(resource.data.clubId)
        && (
          resource.data.authorUid == request.auth.uid
          || isAdminForClub(resource.data.clubId)
        );
    }

    // Migration tracking: only authenticated users can read; writes handled server-side
    match /_migrations/{docId} {
      allow read, write: if isSignedIn();
    }
  }
}
